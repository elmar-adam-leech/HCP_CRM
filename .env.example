# =============================================================================
# HCPCRM — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to version control.
#
# Legend:
#   [Required]  — App will not start or core features will break without this
#   [Optional]  — Feature degrades gracefully if missing
#   [Dev only]  — Only needed in local development; not used in production
#   [Auto]      — Set automatically by Replit; do not set manually on Replit
# =============================================================================


# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# [Required] PostgreSQL connection string (Neon recommended)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# [Required] Secret used to sign JWT auth tokens — use a long random string
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# [Optional] How long JWT tokens last before expiring (default: 7d)
JWT_EXPIRES_IN=7d

# [Required] Set to "production" on any non-dev host to enable secure cookies,
# production error handling, and static file serving
NODE_ENV=production

# [Optional] Port to listen on (default: 5000)
PORT=5000

# [Optional] Public URL of your deployed app — used in password reset email links
# Example: https://yourapp.com
APP_URL=


# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------

# [Required] 32-byte hex key used to encrypt stored credentials (Gmail tokens, etc.)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# Gmail / Google OAuth
# -----------------------------------------------------------------------------
# Required for the per-user Gmail integration (sync inbox, send emails).
# Create credentials at: https://console.cloud.google.com/apis/credentials
# OAuth type: Web application
# Add your production domain to "Authorized redirect URIs":
#   https://yourapp.com/api/oauth/gmail/callback

# [Required for Gmail] Google OAuth client ID
GOOGLE_OAUTH_CLIENT_ID=

# [Required for Gmail] Google OAuth client secret
GOOGLE_OAUTH_CLIENT_SECRET=

# [Required for Gmail] Comma-separated list of domains allowed as OAuth redirect hosts.
# On Replit this is set automatically via REPLIT_DOMAINS — only set this for external hosts.
# Example: yourapp.com,www.yourapp.com
ALLOWED_REDIRECT_DOMAINS=


# -----------------------------------------------------------------------------
# SendGrid (transactional emails: welcome, password reset, etc.)
# -----------------------------------------------------------------------------
# If not set, these emails are silently skipped — signup/password reset still work
# but no confirmation emails are sent.

# [Optional] SendGrid API key (starts with "SG.")
SENDGRID_API_KEY=

# [Optional] From address for system emails (default: noreply@hcpcrm.com)
SENDGRID_FROM_EMAIL=


# -----------------------------------------------------------------------------
# Dialpad (SMS and calling)
# -----------------------------------------------------------------------------

# [Optional] Dialpad API key — required for SMS and calling features
DIALPAD_API_KEY=

# [Optional] Dialpad API base URL (default: https://dialpad.com/api/v2)
DIALPAD_API_BASE_URL=https://dialpad.com/api/v2


# -----------------------------------------------------------------------------
# Housecall Pro
# -----------------------------------------------------------------------------

# [Optional] Webhook secret for validating incoming HCP webhook payloads
HOUSECALL_PRO_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# AI (xAI / Grok)
# -----------------------------------------------------------------------------

# [Optional] xAI API key — required for AI features in workflow automation
XAI_API_KEY=


# -----------------------------------------------------------------------------
# Replit-injected variables (do NOT set these manually on Replit)
# These are provided automatically by the Replit platform.
# On external hosts, use ALLOWED_REDIRECT_DOMAINS instead of REPLIT_DOMAINS.
# -----------------------------------------------------------------------------

# [Auto] Comma-separated list of Replit preview/production domains
# REPLIT_DOMAINS=

# [Auto] Replit deployment ID — used for build version tracking only
# REPLIT_DEPLOYMENT_ID=

# [Auto] Replit identity token — was used by legacy SendGrid connector (no longer needed)
# REPL_IDENTITY=

# [Auto] Replit connectors hostname — was used by legacy SendGrid connector (no longer needed)
# REPLIT_CONNECTORS_HOSTNAME=
